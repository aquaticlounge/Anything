-- Executor script: Permanent backpack for Satchel/Loadout + Anti-Freeze Protection

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer
local Modules = ReplicatedStorage:WaitForChild("Modules")
local SatchelModule = Modules:WaitForChild("Satchel")
local LoadoutModule = require(SatchelModule)

-- HOOK 1: Override SetBackpackEnabled to always enable
if LoadoutModule then
    if LoadoutModule.SetBackpackEnabled then
        local original = LoadoutModule.SetBackpackEnabled
        function LoadoutModule:SetBackpackEnabled(enable)
            -- Force it to always enable backpack regardless of input
            original(self, true)
        end
    end
end

-- HOOK 2: Block backpack item added delays
for _, child in ipairs(SatchelModule:GetChildren()) do
    if child.Name == "BackpackItemAdded" and child:IsA("RemoteEvent") then
        child.Event:Connect(function()
            -- Force enable backpack immediately when item added
            if LoadoutModule.SetBackpackEnabled then
                LoadoutModule:SetBackpackEnabled(true)
            end
        end)
    end
end

-- HOOK 3: Continuous enforcement thread
task.spawn(function()
    while task.wait(0.1) do
        if LoadoutModule.SetBackpackEnabled then
            LoadoutModule:SetBackpackEnabled(true)
        end
    end
end)

-- HOOK 4: Re-enable on character spawn
localPlayer.CharacterAdded:Connect(function(char)
    task.wait(0.5)
    if LoadoutModule.SetBackpackEnabled then
        LoadoutModule:SetBackpackEnabled(true)
    end
end)

-- NEW: Override CustomBackpackController to prevent freeze/disable states
-- This targets the script that handles "Freezed", "BeingArrested", etc.
local function overrideBackpackController()
    task.wait(1) -- Wait for game to load
    
    -- Find and override the CustomBackpackController module
    local success, CustomBackpackModule = pcall(function()
        return require(script.Parent.CustomBackpackController)
    end)
    
    if success and CustomBackpackModule then
        -- Override _canEnable to always return true
        if CustomBackpackModule._canEnable then
            CustomBackpackModule._canEnable = function()
                return true -- Always allow backpack
            end
        end
        
        -- Override _toggleBackpackTo to force enable
        if CustomBackpackModule._toggleBackpackTo then
            local originalToggle = CustomBackpackModule._toggleBackpackTo
            CustomBackpackModule._toggleBackpackTo = function(self, enabled)
                -- Force enable, ignore any disable attempts
                originalToggle(self, true)
            end
        end
        
        -- Override _disable to do nothing
        if CustomBackpackModule._disable then
            CustomBackpackModule._disable = function() 
                -- Do nothing - prevent backpack from being disabled
                return 
            end
        end
        
        -- Override _disableSpam to prevent spam protection
        if CustomBackpackModule._disableSpam then
            CustomBackpackModule._disableSpam = function()
                -- Do nothing - prevent spam disable
                return
            end
        end
        
        -- Force enable immediately
        if CustomBackpackModule._enable then
            CustomBackpackModule:_enable()
        end
    end
end

-- NEW: Hook into player attribute changes to block disable attempts
local function blockDisableAttributes()
    -- Monitor and override any attributes that try to disable backpack
    local attributesToBlock = {
        "Freezed",
        "BeingArrested",
        "BeingDogLeashed",
        "BeingTombstoneTrapped",
        "USER_DRIVING",
        "USER_VEHICLE_SITTING",
        "IN_DRESS_ROOM",
        "CARRYING_EGG",
        "UNDERGROUND_FIGHTING",
        "BeingSchoolLockerTrapped"
    }
    
    -- Force override attributes to false when they're set
    for _, attrName in ipairs(attributesToBlock) do
        localPlayer:GetAttributeChangedSignal(attrName):Connect(function()
            -- Don't actually change the attribute, just ensure backpack stays enabled
            if LoadoutModule.SetBackpackEnabled then
                LoadoutModule:SetBackpackEnabled(true)
            end
            
            -- Also force CustomBackpackController to enable if we have it
            pcall(function()
                local CustomBackpackModule = require(script.Parent.CustomBackpackController)
                if CustomBackpackModule and CustomBackpackModule._enable then
                    CustomBackpackModule:_enable()
                end
            end)
        end)
    end
end

-- NEW: Extra protection - hook into Humanoid state changes
localPlayer.CharacterAdded:Connect(function(character)
    task.wait(0.5)
    local humanoid = character:WaitForChild("Humanoid")
    
    -- Monitor humanoid state changes that might disable backpack
    if humanoid then
        humanoid.StateChanged:Connect(function(oldState, newState)
            task.wait() -- Small delay to let other scripts run
            if LoadoutModule.SetBackpackEnabled then
                LoadoutModule:SetBackpackEnabled(true)
            end
        end)
    end
end)

-- NEW: Hook into the original CustomBackpackController's Start function
local function hookOriginalController()
    local success, module = pcall(function()
        return require(script.Parent.CustomBackpackController)
    end)
    
    if success and module and module.Start then
        local originalStart = module.Start
        module.Start = function(self, ...)
            -- Call original but then override the connections
            originalStart(self, ...)
            
            -- Disconnect or override the freeze/arrest connections
            -- This is more aggressive but ensures permanent backpack
            task.wait(0.1)
            
            -- Re-apply our overrides after original start
            if self._canEnable then
                self._canEnable = function() return true end
            end
            if self._toggleBackpackTo then
                self._toggleBackpackTo = function(_, enabled) 
                    return self:_toggleBackpackTo(true)
                end
            end
            self:_enable()
        end
    end
end

-- Initialize all protections
task.spawn(overrideBackpackController)
task.spawn(blockDisableAttributes)
task.spawn(hookOriginalController)

-- Final protection: periodic re-enforcement of backpack state
task.spawn(function()
    while task.wait(0.5) do
        pcall(function()
            -- Multiple layers of protection
            if LoadoutModule and LoadoutModule.SetBackpackEnabled then
                LoadoutModule:SetBackpackEnabled(true)
            end
            
            local CustomBackpackModule = require(script.Parent.CustomBackpackController)
            if CustomBackpackModule then
                if CustomBackpackModule._enable then
                    CustomBackpackModule:_enable()
                end
                if CustomBackpackModule._toggleBackpackTo then
                    CustomBackpackModule:_toggleBackpackTo(true)
                end
                CustomBackpackModule._enabled = true
            end
        end)
    end
end)

print("Permanent Backpack + Anti-Freeze Protection Loaded!")
